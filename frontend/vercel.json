{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-production-backend-url.com/api/$1"
    },
    {
      "source": "/audio/(.*)",
      "destination": "https://your-production-backend-url.com/audio/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
